# Telegram
TELEGRAM_BOT_TOKEN=

# Optional: Local Bot API base for files >50MB (e.g. http://127.0.0.1:8081)
# TELEGRAM_API_BASE=https://api.telegram.org

# Delivery tuning
# DELIVERY_BATCH_SIZE=8
# DELIVERY_MAX_FILE_MB=100

# Supabase (server)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (client / Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# App URL (used for product images in Telegram)
PUBLIC_APP_URL=https://your-project.vercel.app

# Admin session (set a long random string in production)
SESSION_SECRET=

# Vercel Cron / self-heal webhook (random string; same value in cron-job.org)
CRON_SECRET=

# Optional: Telegram webhook secret_token (if set, must match setWebhook)
TELEGRAM_WEBHOOK_SECRET=
